# API base URL (empty = same origin via Vite proxy in dev, or same domain in prod)
VITE_API_URL=

# WebSocket server URL (empty = same origin via Vite proxy → Kong)
VITE_WS_URL=

# Keycloak base URL (used for OIDC password grant in dev; defaults to http://localhost:8080)
VITE_KEYCLOAK_URL=http://localhost:8080
