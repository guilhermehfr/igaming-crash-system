# Server Configuration
PORT=4001
NODE_ENV=development

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=admin
DB_PASS=admin
DB_NAME=games

# Message Queue Configuration
RABBITMQ_URL=amqp://admin:admin@rabbitmq:5672

# Game Configuration
# The crash point will be set to the value of CRASH_POINT_OVERRIDE instead of being randomly generated.
# Useful for testing purposes.
CRASH_POINT_OVERRIDE=2.0

# Production / Platform Deployments
# DATABASE_URL overrides DB_HOST, DB_PORT, DB_USER, DB_PASS, DB_NAME when set.
# Useful for platforms like Render/Railway that provide a single connection string.
DATABASE_URL=
DB_SSL=true
CORS_ORIGIN=http://localhost:5173
