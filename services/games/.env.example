# Server Configuration
PORT=4001

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=admin
DB_PASS=admin
DB_NAME=games
DATABASE_URL=postgresql://admin:admin@postgres:5432/games

# Message Queue Configuration
RABBITMQ_URL=amqp://admin:admin@rabbitmq:5672

# Game Configuration
# The crash point will be set to the value of CRASH_POINT_OVERRIDE instead of being randomly generated.
# Useful for testing purposes.
CRASH_POINT_OVERRIDE=0.0
