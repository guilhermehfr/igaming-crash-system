# Server Configuration
PORT=4002
NODE_ENV=development

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=admin
DB_PASS=admin
DB_NAME=wallets

# Message Queue Configuration
RABBITMQ_URL=amqp://admin:admin@rabbitmq:5672

# Production / Platform Deployments
# DATABASE_URL overrides DB_HOST, DB_PORT, DB_USER, DB_PASS, DB_NAME when set.
# Useful for platforms like Render/Railway that provide a single connection string.
DATABASE_URL=
DB_SSL=true
CORS_ORIGIN=http://localhost:5173
