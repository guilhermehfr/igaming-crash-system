# Demo service configuration (for Render deployment)
# Copy this to .env and fill in the values

# PostgreSQL connection (Neon connection string)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/crash_demo?sslmode=require

# JWT signing key (generate with: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-random-secret

# CORS origin (Vercel frontend URL)
CORS_ORIGIN=https://your-app.vercel.app

# Node environment
NODE_ENV=production

# Optional: force a specific crash point for testing
# CRASH_POINT_OVERRIDE=2.0
