{
  "name": "crash-game",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*",
    "frontend/*"
  ],
  "scripts": {
    "docker:up": "docker compose up",
    "docker:up:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v --rmi all --remove-orphans"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
